    "copyright": "© Mendix Technology BV 2026. All rights reserved.",
    "license": "Apache-2.0",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/mendix/web-widgets.git"
    },
    "mxpackage": {
        "type": "module",
        "name": "Pusher",
        "mpkName": "Pusher.mpk",
        "dependencies": [
            "@mendix/pusher-web"
        ]
    },
    "moduleFolderNameInModeler": "pusher",
    "marketplace": {
        "minimumMXVersion": "10.21.1.64969",
        "appName": "Pusher",
        "appNumber": 107957
